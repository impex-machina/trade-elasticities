# ============================================================================
# R / RStudio
# ============================================================================
.Rhistory
.RData
.Rapp.history
.Rproj.user/
*.Rproj

# ============================================================================
# renv (D38; the library is local and machine-specific, the lockfile is
# committed). renv also writes its own renv/.gitignore for the subtree.
# ============================================================================
renv/library/
renv/local/
renv/cellar/
renv/staging/
renv/python/
renv/sandbox/

# ============================================================================
# Environment files - never commit credentials
# ============================================================================
.Renviron
.env
*.pem
*.key
.aws/

# ============================================================================
# OS / IDE junk
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ============================================================================
# Data tier (D16)
# Ignore EVERYTHING under data/ except the manifest. This deliberately covers
# data/raw/, data/derived/, and any other working subdirectory (data/legacy/,
# data/refactored_run_*/, data/smoke_test_*/ etc.) that may exist locally as
# staging/archive copies. Published outputs live on HuggingFace and are pulled
# into data/derived/ by scripts/download_outputs.R; none of them are committed.
# data/manifest.csv is the single committed artifact in the data tier.
# ============================================================================
data/*
!data/manifest.csv
!data/raw/
data/raw/*
!data/raw/.gitkeep
!data/derived/
data/derived/*
!data/derived/.gitkeep

# ============================================================================
# Internal refactor artifacts - not part of the published replication
# artifact (Gate 2, N+12). docs/audits/ are working grep/introspection dumps
# from the rebuild and reference a legacy_source_snapshot that is not in the
# repo; the reader-facing methodology lives in docs/methodology/*.md. The
# tier4 console capture embeds local absolute paths and is superseded by the
# published tier4_comp.csv.
# ============================================================================
docs/audits/
docs/methodology/tier4_console.txt

# ============================================================================
# Working artifacts
# ============================================================================
*.log
logs/

# ============================================================================
# Scratch tooling and stray archives - not part of the published artifact.
# These are one-off helpers and download/extract leftovers from the build.
# ============================================================================
reinventory.R
migrate_tests_to_validation.ps1
*.zip
*.tar.gz
*.tar

# ============================================================================
# Build outputs
# ============================================================================
*.o
*.so
*.dll

# ============================================================================
# Generated analysis outputs (regenerated by analysis/master.R; not committed)
# ============================================================================
analysis/figures/

# ============================================================================
# Local-only architecture / design notes
# Documents that describe the repo's internal architecture in
# diary/retrospective tone, intended for the author's reference but not
# part of the public artifact. The build-artifact mechanism itself
# (build_readme.R, the pre-commit hook, .gitattributes) IS public; only
# the prose explanation of how it was built and why is local.
# ============================================================================
docs/methodology/build_readme.md
results/audits/
results/stage2_dgp_summary_quick.json
